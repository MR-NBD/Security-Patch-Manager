# ============================================================
# SPM DASHBOARD (Streamlit) - Environment Variables
# Copia in streamlit/.env e personalizza i valori
# ============================================================

# --- API Flask ---
# URL dell'Orchestrator Flask. Default localhost perché entrambi
# i servizi girano sulla stessa VM.
SPM_API_URL=http://localhost:5001

# --- API Security ---
# Stessa chiave impostata in SPM_API_KEY del .env Flask.
# Genera con: python3 -c "import secrets; print(secrets.token_hex(32))"
SPM_API_KEY=change-me-to-a-random-hex-string

# --- Azure AD SSO ---
AZURE_TENANT_ID=fae8df93-7cf5-40da-b480-f272e15b6242
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=https://10.172.2.22:8501
